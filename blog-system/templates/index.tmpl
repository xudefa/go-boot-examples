<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{{.title}}</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .article { border-bottom: 1px solid #eee; padding: 20px 0; }
        .article-title { font-size: 1.5em; font-weight: bold; margin-bottom: 10px; }
        .article-content { color: #555; line-height: 1.6; }
        .article-meta { font-size: 0.9em; color: #999; margin-top: 10px; }
    </style>
</head>
<body>
    <h1>{{.title}}</h1>
    
    {{range .articles}}
    <div class="article">
        <div class="article-title">{{.Title}}</div>
        <div class="article-content">{{.Content}}</div>
        <div class="article-meta">作者: {{.Author.Username}} | 时间: {{.Created.Format "2006-01-02 15:04:05"}}</div>
    </div>
    {{end}}
    
    {{if not .articles}}
    <p>暂无文章</p>
    {{end}}
</body>
</html>